{
    "name": "Pienza DS Environment",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },

    // 1. AJUSTE: Añadimos python3-pip a la instalación de sistema y forzamos el upgrade de pip
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y graphviz python3-pip && python3 -m pip install --upgrade pip && pip install -r requirements.txt",

    "customizations": {
        "vscode": {
            // 2. AJUSTE: Forzamos a que VS Code use tu Python de trabajo por defecto para evitar que "busque" en el sistema
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.analysis.typeCheckingMode": "basic"
            },
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-python.vscode-pylance",
                "mechatroner.rainbow-csv",
                "christian-kohler.path-intellisense"
            ]
        }
    },

    "remoteUser": "vscode"
}